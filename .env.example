# ============================================
# Copilot Chat GUI — Environment Variables
# ============================================
# Copy this file to .env and fill in values.

# --- GitHub Authentication ---
# Option 1: Explicit token (highest priority)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# Option 2: Uses logged-in GitHub CLI user (default, no config needed)

# --- Server ---
PORT=3001
HOST=127.0.0.1
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://[::1]:5173,http://localhost:3001,http://127.0.0.1:3001,http://[::1]:3001
# VITE_SERVER_URL=http://127.0.0.1:3001
# VITE_SERVER_ACCESS_TOKEN=change-me
# SERVER_ACCESS_TOKEN=change-me
# REQUIRE_ACCESS_TOKEN=true
# Production note: set explicit origins only (never use `*`)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# --- Permission policy ---
# STRICT_TOOL_PERMISSIONS=true   # trueで read/url/mcp 以外を拒否（既定: 非ローカル運用時true）
# PERMISSION_ALLOW_KINDS=read,url,mcp

# --- BYOK (Bring Your Own Key) — Optional ---
# Uncomment to use your own API key instead of GitHub Copilot subscription
# BYOK_PROVIDER=openai          # openai | azure | anthropic
# BYOK_API_KEY=sk-xxxxxxx
# BYOK_BASE_URL=https://api.openai.com/v1
# BYOK_MODEL=gpt-4.1

# --- Copilot CLI ---
# COPILOT_CLI_PATH=copilot       # Path to copilot CLI binary (未設定時は自動探索)
# COPILOT_MODELS=gpt-5,gpt-4.1   # models:list 取得失敗時のフォールバックモデル（任意）
# COPILOT_LOG_LEVEL=info         # none | error | warning | info | debug | all
# ENABLE_WEB_SEARCH_FALLBACK=true
# WEB_SEARCH_FALLBACK_MODEL=gpt-5-mini
# WEB_SEARCH_FALLBACK_TIMEOUT_MS=90000
# WEB_SEARCH_FALLBACK_ALLOW_ALL_URLS=false
# WEB_SEARCH_FALLBACK_ALLOWED_URLS=weather.gov,www.jma.go.jp,tenki.jp,www.bbc.com,www.reuters.com,apnews.com,www.nhk.or.jp,www.nikkei.com
# WEB_SEARCH_FALLBACK_DEFAULT_LOCATION=Tokyo, Japan
# WEB_SEARCH_FALLBACK_DEFAULT_LOCALE=ja-JP
# WEB_SEARCH_FALLBACK_DEFAULT_TIMEZONE=Asia/Tokyo
