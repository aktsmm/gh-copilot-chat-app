{
  "name": "copilot-chat-desktop",
  "version": "1.0.0",
  "private": true,
  "author": "yamapan",
  "license": "MIT",
  "description": "Desktop GUI for GitHub Copilot Chat — powered by @github/copilot-sdk",
  "main": "dist/desktop/src/main.js",
  "type": "module",
  "scripts": {
    "compile": "tsc",
    "dev": "npm run compile && electron .",
    "build": "npm run compile && electron-builder",
    "build:win": "npm run compile && electron-builder --win && node scripts/patch-exe.mjs",
    "build:mac": "npm run compile && electron-builder --mac",
    "build:linux": "npm run compile && electron-builder --linux"
  },
  "build": {
    "appId": "com.copilot-chat.desktop",
    "productName": "GitHub Copilot Chat",
    "files": [
      "dist/**/*",
      "!dist/**/*.map",
      "!**/node_modules/**/electron/**",
      "!**/node_modules/**/electron-builder/**",
      "!**/node_modules/**/app-builder-bin/**",
      "!**/node_modules/**/app-builder-lib/**",
      "!**/node_modules/**/builder-util/**",
      "!**/node_modules/**/builder-util-runtime/**",
      "!**/node_modules/**/7zip-bin/**",
      "!**/node_modules/**/electron-winstaller/**",
      "!**/node_modules/**/postject/**",
      "!**/node_modules/**/rcedit/**",
      "!**/node_modules/**/typescript/**",
      "!**/node_modules/**/vite/**",
      "!**/node_modules/**/@esbuild/**",
      "!**/node_modules/**/esbuild/**",
      "!**/node_modules/**/tailwindcss/**",
      "!**/node_modules/**/postcss/**",
      "!**/node_modules/**/autoprefixer/**",
      "!**/node_modules/**/eslint/**",
      "!**/node_modules/**/lucide-react/**",
      "!**/node_modules/**/react/**",
      "!**/node_modules/**/react-dom/**",
      "!**/node_modules/**/@types/**",
      "!**/node_modules/**/@github/copilot/prebuilds/darwin-*/**",
      "!**/node_modules/**/@github/copilot/prebuilds/linux-*/**",
      "!**/node_modules/**/@github/copilot/prebuilds/win32-arm64/**",
      "!**/node_modules/**/@github/copilot/ripgrep/bin/darwin-*/**",
      "!**/node_modules/**/@github/copilot/ripgrep/bin/linux-*/**",
      "!**/node_modules/**/copilot-chat-desktop/**",
      "!**/node_modules/**/client/**",
      "!**/node_modules/**/server/**"
    ],
    "extraResources": [
      {
        "from": "../server/dist",
        "to": "server"
      },
      {
        "from": "../client/dist",
        "to": "client"
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon-1024.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@github/copilot-sdk": "latest",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "electron-store": "^10.0.0",
    "express": "^5.0.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.5",
    "@types/uuid": "^10.0.0",
    "electron": "35.7.5",
    "electron-builder": "^26.8.1",
    "rcedit": "^5.0.2",
    "typescript": "^5.7.3"
  }
}
